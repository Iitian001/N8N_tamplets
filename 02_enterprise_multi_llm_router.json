    {
      "id": "normalize-response",
      "name": "Normalize Model Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1750,
        150
      ],
      "parameters": {
        "jsCode": "// Works for both Anthropic and OpenAI response shapes, and for error passthroughs\nconst item = $input.first().json;\nconst latency = Date.now() - (item.requestStartedAt || Date.now());\n\nlet modelUsed = 'unknown';\nlet outputText = '';\nlet inputTokens = 0;\nlet outputTokens = 0;\nlet errored = false;\nlet errorMessage = null;\n\nif (item.error) {\n  errored = true;\n  errorMessage = JSON.stringify(item.error);\n} else if (item.content && Array.isArray(item.content)) {\n  // Anthropic shape\n  modelUsed = item.model || 'claude';\n  outputText = item.content.map(c => c.text || '').join('');\n  inputTokens = item.usage?.input_tokens || 0;\n  outputTokens = item.usage?.output_tokens || 0;\n} else if (item.choices && Array.isArray(item.choices)) {\n  // OpenAI shape\n  modelUsed = item.model || 'gpt';\n  outputText = item.choices[0]?.message?.content || '';\n  inputTokens = item.usage?.prompt_tokens || 0;\n  outputTokens = item.usage?.completion_tokens || 0;\n} else {\n  errored = true;\n  errorMessage = 'Unrecognized response shape from model provider';\n}\n\n// Rough cost estimates (USD per 1K tokens) - update to match current pricing\nconst costTable = {\n  'claude-opus-4-7': { in: 0.015, out: 0.075 },\n  'gpt-4-turbo': { in: 0.01, out: 0.03 },\n  'gpt-3.5-turbo': { in: 0.0005, out: 0.0015 }\n};\nconst rates = costTable[modelUsed] || { in: 0, out: 0 };\nconst cost = ((inputTokens / 1000) * rates.in) + ((outputTokens / 1000) * rates.out);\n\nreturn [{\n  json: {\n    success: !errored,\n    model: modelUsed,\n    complexity: item.complexity,\n    output: outputText,\n    inputTokens,\n    outputTokens,\n    totalTokens: inputTokens + outputTokens,\n    cost: Math.round(cost * 100000) / 100000,\n    latencyMs: latency,\n    errorMessage\n  }\n}];"
      }
    },
    {
      "id": "cost-tracker",
      "name": "Cost & Latency Logger (InfluxDB)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
