        "url": "={{ $env.INFLUXDB_URL }}/api/v2/write?bucket=llm_metrics&precision=ms",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ 'Token ' + $env.INFLUXDB_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "text/plain"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "body": "={{ 'llm_request,model=' + $json.model + ',complexity=' + $json.complexity + ',success=' + $json.success + ' tokens=' + $json.totalTokens + ',cost=' + $json.cost + ',latency_ms=' + $json.latencyMs + ' ' + Date.now() }}",
        "options": {
          "timeout": 10000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2
    },
    {
