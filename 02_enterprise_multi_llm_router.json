        "responseBody": "={{ { success: $('Normalize Model Response').item.json.success, model: $('Normalize Model Response').item.json.model, output: $('Normalize Model Response').item.json.output, usage: { totalTokens: $('Normalize Model Response').item.json.totalTokens, estimatedCostUsd: $('Normalize Model Response').item.json.cost, latencyMs: $('Normalize Model Response').item.json.latencyMs } } }}",
        "options": {}
      }
    }
